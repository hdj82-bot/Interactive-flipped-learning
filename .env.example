# ── HeyGen ──────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_CALLBACK_URL=http://localhost:8001/api/webhooks/heygen

# ── TTS: ElevenLabs (primary) ───────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET=ifl-videos
S3_PREFIX=heygen/

# ── Celery / Redis ──────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_URL=redis://redis:6379/1

# ── PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ifl:ifl@postgres:5432/ifl_heygen
DATABASE_URL_SYNC=postgresql://ifl:ifl@postgres:5432/ifl_heygen

# ── Notification ────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=

# ── Polling ─────────────────────────────────────────────
POLLING_INTERVAL_SECONDS=600
