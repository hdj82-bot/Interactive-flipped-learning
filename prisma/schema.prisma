generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  professor
  student
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String
  googleSub     String?            @unique @map("google_sub")
  role          UserRole
  school        String?
  department    String?
  studentNumber String?            @map("student_number")
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  sessions      SessionLog[]
  qaLogs        QALog[]
  assessments   AssessmentResult[]

  @@map("users")
}

enum SessionStatus {
  NOT_STARTED
  IN_PROGRESS
  QA_MODE
  PAUSED
  ASSESSMENT
  COMPLETED
}

model SessionLog {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  lectureId       String        @map("lecture_id")
  status          SessionStatus @default(NOT_STARTED)
  progressPct     Float         @default(0) @map("progress_pct")
  watchedSec      Int           @default(0) @map("watched_sec")
  totalSec        Int           @default(0) @map("total_sec")
  noResponseCnt   Int           @default(0) @map("no_response_cnt")
  pauseReason     String?       @map("pause_reason")
  startedAt       DateTime?     @map("started_at")
  completedAt     DateTime?     @map("completed_at")
  lastActiveAt    DateTime?     @map("last_active_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lectureId])
  @@map("session_logs")
}

// ── Q&A 로그 ──

model QALog {
  id          String   @id @default(uuid())
  lectureId   String   @map("lecture_id")
  sessionId   String   @map("session_id")
  userId      String   @map("user_id")
  question    String
  answer      String?
  timestamp   Float    @default(0)
  tokensUsed  Int      @default(0) @map("tokens_used")
  responded   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([lectureId])
  @@index([sessionId])
  @@map("qa_logs")
}

// ── 평가 결과 ──

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

model AssessmentResult {
  id            String       @id @default(uuid())
  lectureId     String       @map("lecture_id")
  sessionId     String       @map("session_id")
  userId        String       @map("user_id")
  questionType  QuestionType @map("question_type")
  questionText  String       @map("question_text")
  correctAnswer String       @map("correct_answer")
  userAnswer    String       @map("user_answer")
  isCorrect     Boolean      @map("is_correct")
  category      String?
  createdAt     DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([lectureId])
  @@index([userId])
  @@map("assessment_results")
}

// ── 비용 로그 ──

enum CostCategory {
  LLM_QA
  LLM_ASSESSMENT
  LLM_SUMMARY
  STT
  TTS
  OTHER
}

model CostLog {
  id          String       @id @default(uuid())
  lectureId   String       @map("lecture_id")
  category    CostCategory
  model       String?
  inputTokens  Int         @default(0) @map("input_tokens")
  outputTokens Int         @default(0) @map("output_tokens")
  costUsd     Float        @default(0) @map("cost_usd")
  memo        String?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([lectureId])
  @@map("cost_logs")
}
